# macOS
.DS_Store
.AppleDouble
.LSOverride

# Large raster/GIS files
*.tif
*.tiff
*.asc
*.nc
*.hdf
*.h5

# Shapefiles (binary components — keep .shp + .shx + .dbf in git only if small)
*.sbn
*.sbx
*.cpg
*.prj

# PDFs (large) — except the paper itself
*.pdf
!paper/main.pdf

# Jupyter / Python
__pycache__/
*.py[cod]
*.ipynb_checkpoints/
.env
.venv/

# Results (large outputs)
results/

# Raw data — track small GeoJSON/JSON/CSV but not large rasters
data/raw/
!data/raw/boundaries/
!data/raw/boundaries/*.geojson
!data/raw/boundaries/*.json
data/raw/boundaries/hp_rivers.geojson
!data/raw/flood_inventory/
!data/raw/flood_inventory/*.json
!data/raw/infrastructure/
!data/raw/infrastructure/*.geojson
data/raw/infrastructure/roads.geojson
data/raw/infrastructure/settlements.geojson
!data/raw/rainfall/DOWNLOAD_INSTRUCTIONS.txt

# Cache directories
.cache/
cache/*
__pycache__/
main.log