# macOS
.DS_Store
.AppleDouble
.LSOverride

# Large raster/GIS files
*.tif
*.tiff
*.asc
*.nc
*.hdf
*.h5

# Shapefiles (binary components — keep .shp + .shx + .dbf in git only if small)
*.sbn
*.sbx
*.cpg
*.prj

# PDFs (large) — except the paper itself
*.pdf
!paper/main.pdf

# Jupyter / Python
__pycache__/
*.py[cod]
*.ipynb_checkpoints/
.env
.venv/

# Results (large outputs) — except dashboard data needed for deployment
results/
!results/dashboard/
!results/dashboard/*.geojson
!results/dashboard/*.json

# Raw data (add manually when needed)
data/raw/

# Cache directories
.cache/
cache/*
__pycache__/
main.log